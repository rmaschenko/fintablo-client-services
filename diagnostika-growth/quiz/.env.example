# diagnostika-growth · переменные окружения для api/lead.php
# Скопировать в quiz/.env на сервере и заполнить значениями amoCRM.
# Без этого файла endpoint всё равно работает — лиды лягут в CSV-бэкап
# (quiz/api/leads/dg_YYYY-MM.csv), но в amoCRM не попадут.

AMO_DOMAIN=fintablo.amocrm.ru
AMO_TOKEN=
AMO_PIPELINE_ID=5278171

# Stage ID на каждый маршрут. Значения уточнить в интерфейсе amoCRM
# (Сделки → Воронки → Diagnostika Growth → ID этапов).
AMO_STATUS_HOT_ICP=47065159
AMO_STATUS_HOT_ICP_NO_FINANCE=
AMO_STATUS_WARM_ICP=
AMO_STATUS_ANTI_ICP=
